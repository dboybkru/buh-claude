# BuhClaude — PRODUCTION root env (for docker-compose).
#
# Copy to .env at the repo root, replace every <placeholder>, and never
# commit it. Backend secrets (JWT_SECRET, DADATA_API_KEY, ...) live in
# backend/.env, NOT here — this file only configures the postgres service
# and the host-facing ports.

# ─── Postgres (compose) ──────────────────────────────────────────────────────
POSTGRES_DB=buhclaude
POSTGRES_USER=buhclaude
# REQUIRED: replace with a long random password. Do not reuse from dev.
POSTGRES_PASSWORD=<REPLACE-WITH-STRONG-DB-PASSWORD>

# ─── Host port mapping ───────────────────────────────────────────────────────
# Frontend is exposed; backend and postgres stay on the compose network.
FRONTEND_PORT=8080
# Uncomment in docker-compose.prod.yml's `backend.ports` if you want to
# expose the API directly (e.g. for monitoring / external integrations).
# BACKEND_PORT=3001

# ─── pgAdmin (optional, dev convenience — disabled in prod by default) ──────
# Start with: docker compose up -d pgadmin
PGADMIN_EMAIL=admin@buhclaude.local
PGADMIN_PASSWORD=<REPLACE-OR-DO-NOT-START-PGADMIN>
PGADMIN_PORT=5050
