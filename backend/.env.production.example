# BuhClaude backend — PRODUCTION env example.
#
# Copy to backend/.env, replace every <placeholder>, and never commit it.
# All values below have no safe defaults — leaving the placeholders in will
# either fail validation on startup or expose the service to predictable
# credentials.
#
# How to generate JWT_SECRET (≥ 32 chars):
#   openssl rand -hex 32
#   # OR PowerShell:
#   # [Convert]::ToBase64String((1..48 | %{ Get-Random -Min 0 -Max 256 } -as [byte[]]))

# ─── Database ────────────────────────────────────────────────────────────────
# Inside docker-compose the host is `postgres` (service name).
# Outside compose use the real host / managed-DB connection string.
DATABASE_URL="postgresql://buhclaude:<DB_PASSWORD>@postgres:5432/buhclaude?schema=public"

# ─── App / runtime ───────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=3001
HOST="0.0.0.0"

# Allowed origins for the SPA — comma-separated, no wildcards, no http://* in prod.
# When the SPA is served through the same nginx that proxies /api, you can
# point this at the public origin of the site (e.g. https://buh.example.ru).
CORS_ORIGIN="https://buh.example.ru"

# ─── JWT / шифрование ────────────────────────────────────────────────────────
# REQUIRED: ≥ 32 chars, randomly generated. Used both for JWT signing and for
# AES-256-GCM encryption of stored AI apiKey values — rotation invalidates
# both. See runbook §"Production-like Docker run".
JWT_SECRET="<REPLACE-WITH-32-CHAR-RANDOM-SECRET>"
JWT_EXPIRES_IN="7d"

# ─── App encryption (Sprint 10 — IntegrationSetting secrets) ────────────────
# Separate key for /admin/system secret bundles (DaData token / SMTP password
# / AI provider apiKey set via the admin UI). Kept SEPARATE from JWT_SECRET so
# rotating one does not invalidate the other.
#   - If APP_ENCRYPTION_KEY is empty, backend falls back to JWT_SECRET-derived
#     key (works, but couples the two rotation lifecycles).
#   - Strongly recommended to set explicitly in production.
# How to generate:
#   openssl rand -base64 32
APP_ENCRYPTION_KEY="<REPLACE-WITH-32-BYTE-BASE64-KEY>"

# ─── Uploads (логотип / печать / подпись) ────────────────────────────────────
# In docker the path is mounted as a named volume (uploads_data → /app/uploads).
UPLOADS_DIR="/app/uploads"
MAX_UPLOAD_SIZE_MB=10

# ─── DaData (legacy fallback) ─────────────────────────────────────────────────
# Sprint 10: prefer to set DaData token/secret via /admin/system (UI). These
# env vars are a fallback used when IntegrationSetting(DADATA) is empty.
DADATA_API_KEY=""
DADATA_SECRET_KEY=""

# ─── Logging ─────────────────────────────────────────────────────────────────
# In production prefer `info`. `debug` and below may log payload sizes / paths
# and shouldn't be used long-term. `silent` disables logs entirely.
LOG_LEVEL="info"
