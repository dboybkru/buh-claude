// BuhClaude — схема базы данных
// Соответствие законодательству РФ: 402-ФЗ, НК РФ ст. 169, приказ ФНС ММВ-7-15/820@

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// USERS & SESSIONS
// =============================================================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizations  Organization[]
  counterparties Counterparty[]
  contracts      Contract[]
  invoices       Invoice[]
  acts           Act[]
  updDocuments   UpdDocument[]
  waybills       Waybill[]
  nomenclature   Nomenclature[]
  documentItems  DocumentItem[]
  sessions       UserSession[]
  payments       Payment[]
  reconciliations ReconciliationAct[]
  aiSettings     AiSettings?
  aiActionPlans  AiActionPlan[]
  aiAuditLogs    AiAuditLog[]
  memberships    OrganizationMember[] @relation("memberUser")
  invitesSent    OrganizationMember[] @relation("inviter")

  @@index([email])
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// =============================================================================
// ORGANIZATIONS (наши собственные)
// =============================================================================

model Organization {
  id                 String    @id @default(uuid())
  userId             String
  type               OrgType
  name               String                       // Краткое наименование (для отображения)
  fullName           String                       // Полное наименование (для документов)
  inn                String                       // ИНН: 10 (юрлицо) или 12 (ИП) цифр
  kpp                String?                      // КПП: 9 цифр (отсутствует у ИП)
  ogrn               String?                      // ОГРН: 13 (юрлицо) или 15 (ИП) цифр
  okpo               String?
  oktmo              String?
  okveds             String[]                     // Коды ОКВЭД
  directorName       String?                      // ФИО руководителя (ООО/АО)
  directorPosition   String?                      // Должность ("Генеральный директор" и т.п.)
  entrepreneurName   String?                      // ФИО предпринимателя (ИП)
  chiefAccountant    String?                      // ФИО главного бухгалтера
  accountantPosition String?                      // Должность бухгалтера ("Главный бухгалтер")
  basedOn            String?    @default("Устава") // На основании чего действует руководитель
  email              String?
  phone              String?
  website            String?
  legalAddress       String                       // Юридический адрес
  actualAddress      String?                      // Фактический адрес (если отличается)
  postalAddress      String?                      // Почтовый адрес
  logo               String?                      // Путь к файлу логотипа
  stamp              String?                      // Путь к скану печати
  signature          String?                      // Путь к скану подписи руководителя
  vatMode            VatMode   @default(GENERAL)  // Режим НДС (реформа 2026: УСН тоже может быть плательщиком)
  taxSystem          TaxSystem @default(OSN)
  isDefault          Boolean   @default(false)    // Организация по умолчанию для новых документов

  // Настройки печатных форм (Sprint 5)
  printShowLogo                Boolean @default(true)
  printShowStamp               Boolean @default(true)
  printShowSignature           Boolean @default(true)
  printShowAccountantSignature Boolean @default(false)
  printShowBankDetails         Boolean @default(true)
  printShowQrCode              Boolean @default(false)
  printDefaultVatText          String?
  printDefaultPaymentTerms     String?
  printDefaultFooterText       String?
  printInvoiceNote             String?
  printActNote                 String?
  printUpdNote                 String?
  printWaybillNote             String?
  printReconciliationNote      String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccounts      BankAccount[]
  contracts         Contract[]
  invoices          Invoice[]
  acts              Act[]
  updDocuments      UpdDocument[]
  waybills          Waybill[]
  numbering         DocumentNumbering[]
  payments          Payment[]
  reconciliations   ReconciliationAct[]
  contractTemplates ContractTemplate[]
  members           OrganizationMember[]

  @@unique([userId, inn])
  @@index([userId])
}

// =============================================================================
// ORGANIZATION MEMBERSHIP — RBAC (Sprint 9)
// Связывает пользователя с организацией и хранит его роль/статус. У каждой
// организации должен быть как минимум один ACTIVE OWNER. Удалить последнего
// OWNER нельзя (см. routes/members.ts).
// userId — null означает INVITED по email, без существующего пользователя
// (для MVP без email-доставки приглашение принимается автоматически после
// регистрации пользователя с этим email).
// =============================================================================

model OrganizationMember {
  id             String                       @id @default(uuid())
  organizationId String
  userId         String?
  role           OrganizationRole             @default(VIEWER)
  status         OrganizationMemberStatus     @default(ACTIVE)
  invitedById    String?                                          // кто пригласил (для аудита)
  invitedEmail   String?                                          // email приглашения (если userId ещё null)
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation("memberUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("inviter",    fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([invitedEmail])
}

enum OrganizationRole {
  OWNER         // полный доступ, не может быть удалён последний
  ADMIN         // почти всё, кроме демоушна owner-а / удаления org
  ACCOUNTANT    // CRUD документов, контрагентов, платежей, bank-import, AI confirm
  VIEWER        // read-only
}

enum OrganizationMemberStatus {
  ACTIVE        // активен
  INVITED       // приглашён, ещё не принял (userId может быть null)
  DISABLED      // отозван доступ (мягкое удаление)
}

model BankAccount {
  id             String  @id @default(uuid())
  organizationId String
  bankName       String                 // Наименование банка
  bik            String                 // БИК: 9 цифр, начинается с 04
  account        String                 // Расчётный счёт: 20 цифр
  corrAccount    String                 // Корреспондентский счёт: 20 цифр
  isDefault      Boolean @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]
  payments     Payment[]

  @@index([organizationId])
}

// =============================================================================
// COUNTERPARTIES (контрагенты)
// =============================================================================

model Counterparty {
  id             String   @id @default(uuid())
  userId         String
  type           OrgType
  inn            String
  kpp            String?
  name           String                    // Краткое наименование
  fullName       String?                   // Полное наименование
  ogrn           String?
  okpo           String?
  legalAddress   String?
  actualAddress  String?
  managementName String?                   // ФИО руководителя
  managementPos  String?                   // Должность руководителя
  email          String?
  phone          String?
  website        String?
  bankAccounts   Json?                     // [{bik, account, corrAccount, bankName, isDefault}]
  dadataRaw      Json?                     // Сырой ответ DaData (для аудита)
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contracts    Contract[]
  invoices     Invoice[]
  acts         Act[]
  updDocuments UpdDocument[]
  waybills     Waybill[]
  payments     Payment[]
  reconciliations ReconciliationAct[]

  @@unique([userId, inn])
  @@index([userId])
  @@index([inn])
}

// =============================================================================
// NOMENCLATURE (справочник товаров/услуг/работ)
// =============================================================================

model Nomenclature {
  id          String    @id @default(uuid())
  userId      String
  code        String                            // Артикул / внутренний код
  name        String                            // Краткое наименование
  fullName    String?                           // Полное наименование (для документов)
  unitMeasure String    @default("шт")          // Единица измерения (отображаемая)
  unitCode    String    @default("796")         // Код ОКЕИ (796 = штука)
  type        NomenType @default(TOVAR)
  vatRate     Decimal   @db.Decimal(5, 2) @default(22.00)
  price       Decimal?  @db.Decimal(15, 2)
  isActive    Boolean   @default(true)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentItems DocumentItem[]

  @@unique([userId, code])
  @@index([userId])
  @@index([name])
}

// =============================================================================
// CONTRACTS (договоры)
// =============================================================================

model Contract {
  id             String         @id @default(uuid())
  userId         String
  organizationId String
  counterpartyId String
  templateId     String?                          // Шаблон, на основе которого создан (Sprint 5)
  number         String
  date           DateTime       @db.Date
  expiryDate     DateTime?      @db.Date         // Дата окончания (если есть)
  subject        String?                          // Предмет договора
  amount         Decimal?       @db.Decimal(15, 2) // Сумма договора
  currency       String         @default("RUB")
  status         ContractStatus @default(ACTIVE)
  autoRenew      Boolean        @default(false)   // Автопролонгация
  description    String?
  fileUrl        String?                          // Скан подписанного договора
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization      @relation(fields: [organizationId], references: [id])
  counterparty Counterparty      @relation(fields: [counterpartyId], references: [id])
  template     ContractTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  invoices     Invoice[]
  acts         Act[]
  updDocuments UpdDocument[]
  waybills     Waybill[]

  @@unique([userId, number])
  @@index([userId])
  @@index([organizationId])
  @@index([counterpartyId])
  @@index([expiryDate])
  @@index([templateId])
}

// =============================================================================
// CONTRACT TEMPLATES (шаблоны договоров — Sprint 5)
// Хранит исходный текст с переменными {{...}}, при создании договора рендерится
// с подстановкой реквизитов организации/контрагента/договора.
// =============================================================================

model ContractTemplate {
  id             String   @id @default(uuid())
  userId         String
  organizationId String?                              // null = доступен для всех организаций пользователя
  name           String
  description    String?
  content        String                               // Текст шаблона (с {{переменными}})
  variables      Json     @default("[]")              // Обнаруженные переменные (для UI подсказок)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contracts    Contract[]

  @@index([userId])
  @@index([organizationId])
}

// =============================================================================
// INVOICES (счета на оплату)
// =============================================================================

model Invoice {
  id             String        @id @default(uuid())
  userId         String
  organizationId String
  counterpartyId String
  contractId     String?
  bankAccountId  String?
  number         String
  date           DateTime      @db.Date
  dueDate        DateTime?     @db.Date              // Срок оплаты
  currency       String        @default("RUB")
  status         InvoiceStatus @default(DRAFT)
  // НДС и суммы (НК РФ ст. 169)
  subtotal       Decimal       @db.Decimal(15, 2) @default(0)   // Без НДС
  vatAmount      Decimal       @db.Decimal(15, 2) @default(0)   // НДС
  total          Decimal       @db.Decimal(15, 2) @default(0)   // Итого с НДС
  vatRate        Decimal       @db.Decimal(5, 2)  @default(22.00)
  vatIncluded    Boolean       @default(true)                    // НДС включён в цену или сверху
  paymentPurpose String?                                          // Назначение платежа
  notes          String?
  paidAt         DateTime?                                        // Дата фактической оплаты
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization        @relation(fields: [organizationId], references: [id])
  counterparty Counterparty        @relation(fields: [counterpartyId], references: [id])
  contract     Contract?           @relation(fields: [contractId], references: [id])
  bankAccount  BankAccount?        @relation(fields: [bankAccountId], references: [id])
  items        DocumentItem[]
  acts         Act[]
  updDocuments UpdDocument[]
  waybills     Waybill[]
  allocations  PaymentAllocation[]

  @@unique([userId, number])
  @@index([userId])
  @@index([status])
  @@index([date])
  @@index([counterpartyId])
}

// =============================================================================
// ACTS (акты выполненных работ / оказанных услуг)
// 402-ФЗ ст. 9 — первичный учётный документ
// =============================================================================

model Act {
  id              String    @id @default(uuid())
  userId          String
  organizationId  String
  counterpartyId  String
  contractId      String?
  invoiceId       String?
  number          String
  date            DateTime  @db.Date
  periodStart     DateTime? @db.Date                  // Начало периода оказания услуг
  periodEnd       DateTime? @db.Date                  // Окончание периода
  subtotal        Decimal   @db.Decimal(15, 2) @default(0)
  vatAmount       Decimal   @db.Decimal(15, 2) @default(0)
  total           Decimal   @db.Decimal(15, 2) @default(0)
  vatRate         Decimal   @db.Decimal(5, 2)  @default(22.00)
  vatIncluded     Boolean   @default(true)
  currency        String    @default("RUB")
  status          DocStatus @default(DRAFT)
  sellerSignatory String?                              // ФИО подписанта со стороны исполнителя
  buyerSignatory  String?                              // ФИО подписанта со стороны заказчика
  notes           String?
  fileUrl         String?                              // Скан подписанного акта
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization   @relation(fields: [organizationId], references: [id])
  counterparty Counterparty   @relation(fields: [counterpartyId], references: [id])
  contract     Contract?      @relation(fields: [contractId], references: [id])
  invoice      Invoice?       @relation(fields: [invoiceId], references: [id])
  items        DocumentItem[]

  @@unique([userId, number])
  @@index([userId])
  @@index([status])
  @@index([date])
}

// =============================================================================
// UPD — УНИВЕРСАЛЬНЫЙ ПЕРЕДАТОЧНЫЙ ДОКУМЕНТ
// Приказ ФНС России от 19.12.2018 № ММВ-7-15/820@
// =============================================================================

model UpdDocument {
  id              String      @id @default(uuid())
  userId          String
  organizationId  String
  counterpartyId  String
  contractId      String?
  invoiceId       String?
  number          String
  date            DateTime    @db.Date
  // Функция: 1 (счёт-фактура + передаточный документ) или 2 (только передаточный)
  functionType    UpdFunction @default(FULL)
  subtotal        Decimal     @db.Decimal(15, 2) @default(0)
  vatAmount       Decimal     @db.Decimal(15, 2) @default(0)
  total           Decimal     @db.Decimal(15, 2) @default(0)
  vatRate         Decimal     @db.Decimal(5, 2)  @default(22.00)
  vatIncluded     Boolean     @default(false)              // В счёте-фактуре НДС обычно сверху
  currency        String      @default("RUB")
  status          DocStatus   @default(DRAFT)
  // Обязательные реквизиты счёта-фактуры (НК РФ ст. 169)
  shipmentDate    DateTime?   @db.Date                     // Дата отгрузки
  shipmentAddress String?                                   // Адрес грузополучателя
  customsDecl     String?                                   // Номер ГТД (для импорта)
  paymentDocRef   String?                                   // К п/п (при предоплате)
  sellerSignatory String?
  buyerSignatory  String?
  notes           String?
  fileUrl         String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization   @relation(fields: [organizationId], references: [id])
  counterparty Counterparty   @relation(fields: [counterpartyId], references: [id])
  contract     Contract?      @relation(fields: [contractId], references: [id])
  invoice      Invoice?       @relation(fields: [invoiceId], references: [id])
  items        DocumentItem[]

  @@unique([userId, number])
  @@index([userId])
  @@index([status])
  @@index([date])
}

// =============================================================================
// WAYBILLS — товарные накладные ТОРГ-12 (ОКУД 0330212)
// =============================================================================

model Waybill {
  id             String    @id @default(uuid())
  userId         String
  organizationId String
  counterpartyId String
  contractId     String?
  invoiceId      String?
  number         String
  date           DateTime  @db.Date
  operationType  WaybillOp @default(SALE)
  subtotal       Decimal   @db.Decimal(15, 2) @default(0)
  vatAmount      Decimal   @db.Decimal(15, 2) @default(0)
  total          Decimal   @db.Decimal(15, 2) @default(0)
  vatRate        Decimal   @db.Decimal(5, 2)  @default(22.00)
  vatIncluded    Boolean   @default(true)
  currency       String    @default("RUB")
  status         DocStatus @default(DRAFT)
  shippedBy      String?                            // ФИО + должность отпустившего
  receivedBy     String?                            // ФИО + должность получившего
  notes          String?
  fileUrl        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization   @relation(fields: [organizationId], references: [id])
  counterparty Counterparty   @relation(fields: [counterpartyId], references: [id])
  contract     Contract?      @relation(fields: [contractId], references: [id])
  invoice      Invoice?       @relation(fields: [invoiceId], references: [id])
  items        DocumentItem[]

  @@unique([userId, number])
  @@index([userId])
  @@index([status])
  @@index([date])
}

// =============================================================================
// DOCUMENT ITEMS — позиции документов
// Полиморфная связь через 4 nullable FK (Prisma-совместимый паттерн)
// =============================================================================

model DocumentItem {
  id             String   @id @default(uuid())
  userId         String
  documentType   DocType                                  // Дискриминатор для приложения
  nomenclatureId String?
  sortOrder      Int      @default(1)
  name           String                                    // Снапшот наименования на момент создания
  unit           String   @default("шт")
  unitCode       String   @default("796")
  quantity       Decimal  @db.Decimal(15, 3) @default(1)
  price          Decimal  @db.Decimal(15, 2)              // Цена за единицу (без НДС если vatIncluded=false)
  vatRate        Decimal  @db.Decimal(5, 2)  @default(22.00)
  subtotal       Decimal  @db.Decimal(15, 2)              // Сумма без НДС
  vatAmount      Decimal  @db.Decimal(15, 2)              // Сумма НДС
  total          Decimal  @db.Decimal(15, 2)              // Итого с НДС
  countryCode    String?                                   // Код страны происхождения (для УПД)
  countryName    String?                                   // Наименование страны
  customsDecl    String?                                   // Номер ГТД (для УПД)
  createdAt      DateTime @default(now())

  // Полиморфные FK — заполняется ровно один в зависимости от documentType
  invoiceId      String?
  actId          String?
  updId          String?
  waybillId      String?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  nomenclature Nomenclature? @relation(fields: [nomenclatureId], references: [id])
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  act          Act?          @relation(fields: [actId],     references: [id], onDelete: Cascade)
  updDoc       UpdDocument?  @relation(fields: [updId],     references: [id], onDelete: Cascade)
  waybill      Waybill?      @relation(fields: [waybillId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([actId])
  @@index([updId])
  @@index([waybillId])
  @@index([userId])
}

// =============================================================================
// RECONCILIATION ACT — акт сверки взаимных расчётов с контрагентом
// Сохраняется как "снимок" (frozen snapshot) с lines в JSON, чтобы при
// последующих изменениях документов исторический акт оставался прежним.
// =============================================================================

model ReconciliationAct {
  id              String   @id @default(uuid())
  userId          String
  organizationId  String
  counterpartyId  String
  number          String                                    // Свободный номер: "АС-2026-001" и т.п.
  date            DateTime @db.Date                         // Дата составления
  periodFrom      DateTime @db.Date
  periodTo        DateTime @db.Date
  openingBalance  Decimal  @db.Decimal(15, 2) @default(0)   // Положительное = долг контрагента
  totalDebit      Decimal  @db.Decimal(15, 2) @default(0)   // Наши требования (счета/акты/УПД)
  totalCredit     Decimal  @db.Decimal(15, 2) @default(0)   // Поступления (платежи)
  closingBalance  Decimal  @db.Decimal(15, 2) @default(0)   // Сальдо на конец периода
  lines           Json     @default("[]")                    // Снимок движений (см. ReconciliationLine в lib)
  status          ReconciliationStatus @default(DRAFT)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])
  counterparty Counterparty @relation(fields: [counterpartyId], references: [id])

  @@unique([userId, number])
  @@index([userId])
  @@index([counterpartyId])
  @@index([periodTo])
}

enum ReconciliationStatus {
  DRAFT
  SENT
  AGREED       // подписан обеими сторонами
  DISAGREED    // расхождения
}

// =============================================================================
// AI ASSISTANT — настройки провайдера для одного пользователя
// Поддерживаем OpenAI-compatible API: OpenAI, VseGPT, AITunnel, любой
// endpoint с тем же контрактом /v1/chat/completions, /v1/models.
// =============================================================================

model AiSettings {
  id          String   @id @default(uuid())
  userId      String   @unique
  provider    String   @default("openai")        // openai / vsegpt / aitunnel / custom / mock / local
  apiKey      String                              // зашифровано симметрично через env JWT_SECRET (см. lib/crypto)
  baseUrl     String   @default("https://api.openai.com/v1")
  model       String   @default("gpt-4o-mini")
  temperature Float    @default(0.2)
  maxTokens   Int      @default(2000)
  enabled     Boolean  @default(true)             // в API маппится как isEnabled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// =============================================================================
// AI ACTION PLAN (Sprint 6A)
// Любой запрос пользователя к AI создаёт ActionPlan в статусе DRAFT.
// AI не пишет бизнес-данные в БД сам — записи появляются только после
// явного подтверждения пользователем через POST /action-plans/:id/confirm.
// =============================================================================

enum AiActionPlanStatus {
  DRAFT       // план создан, ждёт подтверждения
  CONFIRMED   // полностью или частично применён
  FAILED      // выполнение упало (например, валидация)
  EXPIRED     // план не был подтверждён в течение TTL — нельзя применять
}

model AiActionPlan {
  id             String              @id @default(uuid())
  userId         String
  organizationId String?                                       // целевая организация (если применимо)
  status         AiActionPlanStatus  @default(DRAFT)
  message        String                                        // исходный пользовательский запрос
  planJson       Json                                          // отрендеренный AI-план (см. lib/ai/schemas.ts:actionPlanSchema)
  resultJson     Json?                                         // итог confirm (applied/skipped/errors)
  createdAt      DateTime            @default(now())
  confirmedAt    DateTime?
  expiresAt      DateTime?

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs      AiAuditLog[]

  @@index([userId])
  @@index([organizationId])
  @@index([status])
}

// =============================================================================
// AI AUDIT LOG (Sprint 6A)
// Аудит подтверждённых AI-действий: какой план, какой action, какая сущность
// создана/обновлена. Хранит payload (как было запрошено) и targetId.
// =============================================================================

model AiAuditLog {
  id             String   @id @default(uuid())
  userId         String
  organizationId String?
  actionPlanId   String?                                       // если запись возникла из ActionPlan
  actionType     String                                        // "create_counterparty" / "create_invoice" / "create_act_from_invoice" / "create_contract" / "analyze_debt"
  targetType     String                                        // "counterparty" / "invoice" / "act" / "contract" / "analysis"
  targetId       String?                                       // id созданной сущности; null для read-only action (analyze_debt)
  payloadJson    Json                                          // payload action — для трассировки
  createdAt      DateTime @default(now())

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionPlan AiActionPlan? @relation(fields: [actionPlanId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
  @@index([actionPlanId])
}

// =============================================================================
// PAYMENTS — оплаты и распределение по счетам
// Один платёж может закрывать несколько счетов (allocations); один счёт может
// быть закрыт несколькими платежами.
// =============================================================================

model Payment {
  id             String   @id @default(uuid())
  userId         String
  organizationId String                           // получатель платежа (наша организация)
  counterpartyId String?                          // плательщик
  bankAccountId  String?                          // на какой расч. счёт зачислен
  date           DateTime @db.Date                // дата платежа
  amount         Decimal  @db.Decimal(15, 2)      // сумма по выписке
  direction      PaymentDirection @default(IN)    // IN — поступление, OUT — расход
  method         PaymentMethod    @default(BANK)
  purpose        String?                          // назначение платежа
  reference      String?                          // № п/п, ссылка на банковский документ
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization          @relation(fields: [organizationId], references: [id])
  counterparty Counterparty?         @relation(fields: [counterpartyId], references: [id])
  bankAccount  BankAccount?          @relation(fields: [bankAccountId], references: [id])
  allocations  PaymentAllocation[]

  @@index([userId])
  @@index([organizationId])
  @@index([counterpartyId])
  @@index([date])
}

// Распределение одного платежа по нескольким счетам (или одного счёта между
// несколькими платежами): allocation — одна "строчка распределения".
model PaymentAllocation {
  id        String  @id @default(uuid())
  paymentId String
  invoiceId String
  amount    Decimal @db.Decimal(15, 2)
  createdAt DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([invoiceId])
}

enum PaymentDirection {
  IN    // поступление (от контрагента)
  OUT   // расход (поставщику)
}

enum PaymentMethod {
  BANK    // банковский перевод
  CASH    // касса
  CARD    // эквайринг
  OTHER
}

// =============================================================================
// DOCUMENT NUMBERING — счётчики автонумерации
// Хранят последний выпущенный номер на (организация, тип документа, год).
// Транзакционно инкрементируются при создании документа.
// =============================================================================

model DocumentNumbering {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  docType        DocType
  year           Int                         // календарный год документа
  lastNumber     Int      @default(0)        // последний выпущенный порядковый номер
  prefix         String   @default("")       // префикс ("INV-", "АКТ-", …) — без номера и года
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, docType, year])
  @@index([userId])
}

