# --- Database ---
DATABASE_URL="postgresql://buhclaude:buhclaude_secret@localhost:5432/buhclaude?schema=public"

# --- App ---
NODE_ENV="development"
PORT=3001
HOST="0.0.0.0"
CORS_ORIGIN="http://localhost:5173"

# --- JWT ---
JWT_SECRET="замени-на-случайную-строку-минимум-32-символа-в-проде"
JWT_EXPIRES_IN="7d"

# --- Uploads ---
UPLOADS_DIR="./uploads"
MAX_UPLOAD_SIZE_MB=10

# --- DaData (опционально, для поиска контрагентов по ИНН) ---
# Зарегистрируйтесь на https://dadata.ru и получите ключи
DADATA_API_KEY=""
DADATA_SECRET_KEY=""

# --- Logging ---
LOG_LEVEL="info"
