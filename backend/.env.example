# BuhClaude backend — пример переменных окружения.
# Скопируйте файл как backend/.env и подставьте свои значения.
# НИКОГДА не коммитьте реальные секреты в git.

# ─── Database ────────────────────────────────────────────────────────────────
# Полный connection string PostgreSQL. В docker-compose имя хоста — "postgres".
DATABASE_URL="postgresql://buhclaude:buhclaude_secret@localhost:5432/buhclaude?schema=public"

# ─── App / runtime ───────────────────────────────────────────────────────────
NODE_ENV="development"      # development | test | production
PORT=3001
HOST="0.0.0.0"

# Разрешённые источники для CORS, через запятую (фронт + любые ваши SPA).
CORS_ORIGIN="http://localhost:5173"

# ─── JWT / шифрование ────────────────────────────────────────────────────────
# JWT_SECRET — минимум 32 символа. Используется и как ключ AES-256-GCM
# для шифрования AI apiKey в БД. Меняя его, вы инвалидируете все сессии и
# делаете прежние зашифрованные ключи нечитаемыми.
JWT_SECRET="замени-на-случайную-строку-минимум-32-символа-в-проде"
JWT_EXPIRES_IN="7d"

# ─── Uploads (логотип / печать / подпись организации) ────────────────────────
# Локальный каталог; в production монтируется как Docker volume.
UPLOADS_DIR="./uploads"
MAX_UPLOAD_SIZE_MB=10

# ─── DaData (опционально — поиск контрагентов по ИНН) ────────────────────────
# Зарегистрируйтесь на https://dadata.ru и получите ключи. Пустые значения
# отключают интеграцию без падения backend.
DADATA_API_KEY=""
DADATA_SECRET_KEY=""

# ─── Logging ─────────────────────────────────────────────────────────────────
# fatal | error | warn | info | debug | trace | silent
# В production рекомендуется info, в dev — debug.
LOG_LEVEL="info"
